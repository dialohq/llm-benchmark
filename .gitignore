# venvs (rebuild via `uv sync`)
.venv*/
**/.venv-*/

# host-side snapshot dir, not ours
.venv-backups/

# HF model cache (~100GB+)
.hf_home/

# python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# logs / scratch
/tmp/
*.log

# benchmark inputs / outputs (kept locally)
.data/

# autoresearch run artifacts (logs, generated config.json, run dirs)
# bench_results.tsv at repo root IS tracked — this only ignores transient
# per-run output below.
.bench_runs/

# user-local query corpus (not redistributable)
queries.csv

# autoresearch loop state pointer
configs/.current_experiment

# nix-ld's ldconfig wrapper drops mktemp files in cwd
tmp.??????????

# Rust build outputs
proxy/target/

# Local Claude Code state
.claude/
.cache/
