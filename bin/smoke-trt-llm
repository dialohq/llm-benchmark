#!/usr/bin/env bash
# Boot trt-llm against gpt-oss-120b, fire one chat completion, shut down.
# Run inside `nix develop .#trt-llm` (which already enforces driver r580+).
set -euo pipefail

ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
cd "$ROOT/trt-llm"
[ -d .venv ] || { echo "✘ venv missing — run: uv sync --extra driver-r580" >&2; exit 1; }
# shellcheck disable=SC1091
. .venv/bin/activate

MODEL=${SMOKE_MODEL:-openai/gpt-oss-120b}
TP=${SMOKE_TP:-2}
PORT=${SMOKE_PORT:-8000}
LOG_DIR=${LOG_DIR:-/tmp/llm-bench-smoke}
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/trt-llm.log"

# --backend pytorch skips the TensorRT engine-build step; same OpenAI
# Triton MoE kernel as vllm/sglang on Hopper. Tight batch/seq budget
# keeps the autotuner warmup short (cold start is ~7 min otherwise).
trtllm-serve "$MODEL" --backend pytorch --tp_size "$TP" \
  --max_batch_size 4 --max_seq_len 4096 \
  --host 127.0.0.1 --port "$PORT" >"$LOG" 2>&1 &
pid=$!
trap 'kill -INT $pid 2>/dev/null; wait $pid 2>/dev/null || true' EXIT

deadline=$(( $(date +%s) + 1200 ))
until curl -fsS "http://127.0.0.1:$PORT/v1/models" >/dev/null 2>&1; do
  kill -0 $pid 2>/dev/null || { echo "✘ trt-llm died — see $LOG" >&2; tail -30 "$LOG" >&2; exit 1; }
  [ "$(date +%s)" -lt "$deadline" ] || { echo "✘ trt-llm ready timeout" >&2; exit 1; }
  sleep 5
done

curl -sS "http://127.0.0.1:$PORT/v1/chat/completions" \
  -H 'Content-Type: application/json' \
  -d "{\"model\":\"$MODEL\",\"messages\":[{\"role\":\"user\",\"content\":\"Hello, my name is\"}],\"temperature\":0,\"max_tokens\":32}" \
  | tee "$LOG_DIR/trt-llm.response.json"
echo
